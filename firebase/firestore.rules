rules_version = '2';

// ============================================================================
// きずなbaton — Firestore セキュリティルール（APP-V2-FIRESTORE / P2a）
// ----------------------------------------------------------------------------
// クライアントの canViewContract(c, viewerId)（shukatsu-prototype.html）の
// **live ステージ**をサーバ側ルールへ写像したもの。権限の真の境界はここ（サーバ）。
//
// canViewContract(live) の対応:
//   mode 'all'（未設定も getVisibility が all 正規化） … owner可 / 承諾share家族=可
//   mode 'selected'                                   … owner可 / liveViewers に viewer の memberId を含む家族のみ可
//   mode 'private'                                    … owner可 / 家族=不可
//   mode 'after_only'                                 … owner可 / live では家族=不可（もしもの時＝emergencyMode P5 ゲート・本ルールでは live 非実効）
//   未知mode                                          … owner可 / 家族=不可（fail-safe）
//
// memberId↔uid ブリッジ: liveViewers は memberId（'m2'）を持つが認証は uid。
//   shares/{ownerUid}_{viewerUid} に viewerMemberId を持たせ、ルールで照合する。
//   この share ドキュメントは P3（Cloud Functions）が招待受諾時に生成する
//   （P2a ではエミュレータテストが合成 share を seed して検証）。
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- 共通ヘルパー ----
    function signedIn() { return request.auth != null; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    function shareRef(ownerUid) {
      return /databases/$(database)/documents/shares/$(ownerUid + '_' + request.auth.uid);
    }
    // owner → 自分（viewer）への「受諾済み」閲覧関係が存在するか
    function hasAcceptedShare(ownerUid) {
      return signedIn()
        && exists(shareRef(ownerUid))
        && get(shareRef(ownerUid)).data.status == 'accepted';
    }
    // getVisibility() 正規化: visibility/mode 未設定は 'all' 扱い（後方互換の鉄則・設計書 §5.3）
    function visMode(data) {
      return (('visibility' in data) && ('mode' in data.visibility))
        ? data.visibility.mode
        : 'all';
    }
    // canViewContract(live) の viewer 側判定（本人でない・承諾 share 保有が前提）。
    // 'private'/'after_only'/未知mode は false（after_only は live 非実効＝emergencyMode ゲート）。
    function canViewLive(ownerUid, data) {
      let mode = visMode(data);
      let mid = get(shareRef(ownerUid)).data.viewerMemberId;
      return mode == 'all'
        || (mode == 'selected'
            && ('visibility' in data)
            && ('liveViewers' in data.visibility)
            && (data.visibility.liveViewers is list)
            && data.visibility.liveViewers.hasAny([mid]));
    }

    // ---- 本人サブツリー users/{uid}/** ----
    match /users/{uid} {
      // プロフィール（表示名・color・同意状態）は本人のみ read/write
      allow read, write: if isSelf(uid);

      // 契約: 本人は全操作可。承諾 share を持つ家族は「見える契約」のみ read（write 不可）。
      // stage-2b: 家族 read を get / list に分離。
      //   get  … 従来どおり canViewLive（visMode 正規化＝visibility 未設定の旧 doc も後方互換で可）
      //   list … クエリフィルタと同形の平坦式（list はクエリからルール成立を静的証明できる形が必要。
      //           viewer は where('visibility.mode','==','all') と
      //           where('visibility.mode','==','selected')+array-contains(viewerMemberId) の2クエリで取得。
      //           visibility 未設定 doc はクエリに載らない＝ミラー側の visibility 正規化が前提）
      match /contracts/{cid} {
        allow read, write: if isSelf(uid);
        allow get: if hasAcceptedShare(uid) && canViewLive(uid, resource.data);
        allow list: if hasAcceptedShare(uid)
          && (resource.data.visibility.mode == 'all'
              || (resource.data.visibility.mode == 'selected'
                  && resource.data.visibility.liveViewers.hasAny(
                       [get(shareRef(uid)).data.viewerMemberId])));
      }

      // 資産: 契約と同じ visibility モデル（§5.1 は contracts のみ列挙だが assets も必要＝補完）
      // APP-CARD-ASSET-MERGE(v101): カード型資産（type=='card'）は last4 を持つため家族へは非公開。
      //   クライアント（buildCloudDocs）は card 資産を cards コレクションへ振り分けるが、万一 assets に
      //   紛れても last4 が漏れないよう family read（get/list）を type!='card' で二重防御する。
      match /assets/{aid} {
        allow read, write: if isSelf(uid);
        allow get: if hasAcceptedShare(uid) && resource.data.type != 'card' && canViewLive(uid, resource.data);
        allow list: if hasAcceptedShare(uid)
          && resource.data.type != 'card'
          && (resource.data.visibility.mode == 'all'
              || (resource.data.visibility.mode == 'selected'
                  && resource.data.visibility.liveViewers.hasAny(
                       [get(shareRef(uid)).data.viewerMemberId])));
      }

      // カード: visibility を持たない（last4 のみ）＝本人 owner-only。家族には非公開
      match /cards/{cardId} {
        allow read, write: if isSelf(uid);
      }

      // 家族名簿: 本人のみ
      match /members/{mid} {
        allow read, write: if isSelf(uid);
      }

      // カテゴリ: 本人 read/write。家族はラベル表示のため read 可
      match /categories/{ckey} {
        allow read, write: if isSelf(uid);
        allow read: if hasAcceptedShare(uid);
      }
    }

    // ---- 閲覧関係 shares/{ownerUid}_{viewerUid} ----
    // 書込は P3（Cloud Functions / admin SDK＝ルールをバイパス）専用。クライアント書込は禁止。
    // read は当事者（owner か viewer が自分）のみ。
    // stage-2b: doc ID split 照合 → フィールドベース照合へ変更。
    //   viewer の「自分宛て share 一覧」クエリ（where('viewerUid','==',auth.uid)）を
    //   証明可能にするため（doc ID 条件は list クエリから静的証明できない）。
    //   buildShareDoc は ownerUid/viewerUid を常に書くためバックフィル不要。
    match /shares/{sid} {
      allow read: if signedIn()
        && (resource.data.viewerUid == request.auth.uid
            || resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }

    // ---- 招待 invitations/{token}（P3 サーバ発行専用・クライアント直接アクセス禁止） ----
    match /invitations/{token} {
      allow read, write: if false;
    }

    // ---- 同意監査証跡 consentLogs/{uid}/entries/{entryId}（追記のみ・改ざん耐性） ----
    // 注: §5.1 の consentLogs/{uid}/{entryId} は doc パス段数規則を満たさないため entries サブコレクション形へ是正
    match /consentLogs/{uid}/entries/{entryId} {
      allow read, create: if isSelf(uid);
      allow update, delete: if false;
    }
  }
}
