# きずなbaton Functions 環境変数（非秘密）— deploy 時に functions/.env として配置
# 秘密情報（API キー）は .env に置かず必ず Firebase Secret で管理すること:
#   firebase functions:secrets:set SENDGRID_API_KEY

# メール送信プロバイダ。本番は 'sendgrid'。未設定だと 'log'（エミュレータ限定）扱い＝
# 本番で呼ばれると明示 throw（OTP 平文ログ残留を防ぐ厳格ゲート）。
EMAIL_PROVIDER=sendgrid

# 送信元メールアドレス（SendGrid の Single Sender Verification 等で認証済みのもの）。
EMAIL_FROM=kizunabaton.official@gmail.com
