# きずなbaton Functions 環境変数（非秘密）— deploy 時に functions/.env として配置
# 秘密情報（API キー）は .env に置かず必ず Firebase Secret で管理すること:
#   firebase functions:secrets:set SENDGRID_API_KEY

# メール送信プロバイダ。本番は 'sendgrid'。未設定だと 'log'（エミュレータ限定）扱い＝
# 本番で呼ばれると明示 throw（OTP 平文ログ残留を防ぐ厳格ゲート）。
EMAIL_PROVIDER=sendgrid

# 送信元メールアドレス（SendGrid で認証済みのもの）。
# ⚠️ OPS-SENDGRID-DOMAIN（招待の実メールE2E前提）:
#   gmail.com / 他社フリーメールの From は DMARC アライメント不可＝招待メールが迷惑メール
#   行きになりやすく、高齢の招待相手が OTP を受け取れない（到達確認の前提が崩れる）。
#   本番は「独自ドメインを取得 → SendGrid の Domain Authentication（SPF/DKIM の CNAME を
#   ドメインの DNS に登録）→ そのドメインの from（例 noreply@example.jp）」に差し替えること。
#   Single Sender Verification でも送信自体は可能だが DMARC 整合せず迷惑判定されやすい。
EMAIL_FROM=noreply@<認証済み独自ドメイン>   # 例: noreply@kizuna-baton.jp（Domain Authentication 済）

# 招待リンクのベースURL（stage-2b）。メール内リンク＝ `${APP_INVITE_BASE_URL}#invite=<token>`。
# index.html は lp.html リダイレクトのためアプリ本体へ直リンクすること。
APP_INVITE_BASE_URL=https://bati10inter-cmd.github.io/kizuna-baton/shukatsu-prototype.html
