<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- きずなbaton Privacy Manifest（APPSTORE-META-PRIVACY / Codex H5）
	     2024-05 以降 App Store 提出に必須。Required Reason API を申告する。
	     正＝docs/app-store-submission-plan.md §6 / TASKS.md APPSTORE-META-PRIVACY。 -->

	<!-- トラッキングしない（ATT 不要・広告SDK無し）。CLAUDE.md データ範囲と一致。 -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- トラッキング用ドメイン無し。 -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- v100（PP v4.0・APP-V2-PP-PRIVACY）: 本人が任意でアカウント作成＋「クラウド保存」を
	     有効化した場合に限り、Firebase（Auth/Firestore）へデータを保管する＝Apple のガイドライン上
	     「収集あり」として申告（オプトインでも申告対象）。全て uid に紐付き（Linked=true）・
	     トラッキング無（Tracking=false）・目的はアプリ機能（端末間同期）のみ。docs/app-store-metadata-draft.md §5 と一致。
	     カード番号フル・口座番号・PIN・マイナンバー等の機密情報そのものは保存しない（CLAUDE.md データ範囲）。 -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- メールアドレス（アカウント作成／Firebase Authentication） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeEmailAddress</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- ユーザーID（Firebase uid） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- 表示名・家族の呼び名 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeName</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- ユーザーコンテンツ（契約・資産メタデータ、所在メモ、家族への引き継ぎメッセージ／クラウド保存有効化時） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherUserContent</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- 支払情報（カード会社名・下4桁／クラウド保存有効化時。カード番号フルは非保存） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePaymentInfo</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- その他の金融情報（契約の月額/年額の金額／クラウド保存有効化時） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherFinancialInfo</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- 購入履歴（APPSTORE-PRIVACY-PURCHASE / 2026-07-17 追記: IAP の有料プラン購入・契約状態。
		     ASC の App Privacy ラベルには 2026-07-11（IAP 導入時）から登録済だったが本マニフェスト側が
		     未申告＝不整合だったため是正。StoreKit の購入資格（entitlement）を uid に紐付けて保持する。 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePurchaseHistory</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- 写真またはビデオ（v122 APP-MEMBER-PHOTO・PP v5.2: 家族メンバーの表示アイコン写真。
		     本人が任意で設定した場合のみ・クラウド保存有効化時に本人のみ可読の members ミラーへ複製。家族には非開示 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePhotosorVideos</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<!-- 製品の操作（v128 APP-FUNNEL-KPI: paywall〔プラン画面〕の初回表示を端末ごとに1回だけ
		     匿名カウントする。サーバ側 metrics/paywall に保管するのは集計整数のみで、uid・時刻・
		     端末識別子は一切保存しない＝**本項のみ Linked=false**（他の申告項目は全て uid 紐付き）。
		     目的は「課金0」が paywall 未到達によるものか拒否によるものかの判別＝Analytics。
		     PP 第4条第1号（機能の維持・改善）・第7条「利用状況の集計分析（個人を特定しない範囲）」と整合。
		     ⚠️ ASC「App のプライバシー」フォーム側にも同項目（使用状況データ>製品の操作・
		     個人と紐づけない・トラッキングなし）を登録すること＝両者の不整合は
		     2026-07-17 の PurchaseHistory と同じ失敗パターン（上記コメント参照）。 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<false/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>
	</array>

	<!-- Required Reason API 申告 -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- @capacitor/preferences（iOS=UserDefaults バッキング）＋ Capacitor core が
			     UserDefaults を利用するため申告。APPSTORE-PERSIST で永続化を Preferences に寄せた。 -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1: アプリ自身のみがアクセスする情報の読み書きに UserDefaults を使用。
				     他アプリ/システムが書いた情報の読み取りや、他アプリから読める書き込みは行わない。 -->
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
